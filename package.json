{
  "name": "@ttwtf/pkg-usage",
  "version": "1.2.0",
  "description": "Analyze which public exports of an npm package/scope are actually used in your project",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./reporters": {
      "types": "./dist/reporters/index.d.ts",
      "import": "./dist/reporters/index.js"
    }
  },
  "bin": {
    "pkg-usage": "./dist/cli.js"
  },
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsup --watch"
  },
  "keywords": [
    "npm",
    "package",
    "usage",
    "exports",
    "angular",
    "analysis",
    "unused",
    "imports"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/apelleti/pkg-usage"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "parse5": "^8.0.0",
    "ts-morph": "^24.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.33",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ]
}
